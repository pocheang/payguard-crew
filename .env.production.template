# 🔐 PayGuard Crew - Production Configuration Template
# Copy this to .env.production and update values

# ==============================================
# 🌍 Environment Configuration
# ==============================================
APP_NAME=payguard-crew
APP_ENV=production  # production, staging, dev

# ==============================================
# 🗄️ Database Configuration (REQUIRED)
# ==============================================
# CRITICAL: Use PostgreSQL or MySQL in production, NOT SQLite
DATABASE_TYPE=postgresql  # postgresql, mysql (NOT sqlite)

# PostgreSQL Configuration
POSTGRES_HOST=postgres-service
POSTGRES_PORT=5432
POSTGRES_DB=payguard
POSTGRES_USER=payguard
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==============================================
# 🔐 Security Configuration (REQUIRED)
# ==============================================
# CRITICAL: Change these in production!
JWT_SECRET_KEY=GENERATE_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS_LONG
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Key Authentication (comma-separated)
API_KEYS=prod-key-1,prod-key-2,prod-key-3

# ==============================================
# 🤖 LLM Configuration (Optional)
# ==============================================
LLM_PROVIDER=disabled  # disabled, openai, deepseek, ollama
ENABLE_CREWAI=false

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# DeepSeek Configuration
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==============================================
# 📊 Monitoring & Observability
# ==============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# OpenTelemetry Tracing
OTEL_ENABLED=true
OTEL_EXPORTER_TYPE=otlp  # otlp, console
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=payguard-crew

# ==============================================
# 🔧 Application Settings
# ==============================================
RAG_TOP_K=3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# CORS Origins (comma-separated, for frontend integration)
CORS_ORIGINS=https://app.example.com,https://dashboard.example.com

# ==============================================
# 📁 Paths (Use absolute paths in production)
# ==============================================
PAYGUARD_DOCS_DIR=/app/docs
SQLITE_DB_PATH=/app/payguard_crew.db  # Only used if DATABASE_TYPE=sqlite

# ==============================================
# 🚀 Rate Limiting
# ==============================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ==============================================
# 🔔 Alerting (Optional)
# ==============================================
# Slack webhook for critical alerts
SLACK_WEBHOOK_URL=

# Email alerts
ALERT_EMAIL_RECIPIENTS=ops@example.com,security@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ==============================================
# 🛡️ Security Headers
# ==============================================
ENABLE_SECURITY_HEADERS=true
ENABLE_RATE_LIMITING=true
ENABLE_API_KEY_AUTH=true

# ==============================================
# 📦 Backup Configuration
# ==============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=payguard-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
