# ============================================
# PayGuard .gitignore - GitHub提交规则
# ============================================

# ==================== 敏感信息（绝对不提交）====================
# 环境变量文件
.env
.env.local
.env.development
.env.production
.env.*.local
*.env.backup

# 只保留示例文件和模板
!.env.example
!.env.*.template
!frontend/.env.example

# 数据库文件
*.db
*.sqlite
*.sqlite3
payguard_crew.db
data/**/*.db

# 日志文件
logs/
*.log
app.log
error.log

# 向量数据库
.chroma/
chroma_db/
*.index
chroma.sqlite3

# ==================== 内部文档（不公开）====================
# 根目录的内部文档
ORGANIZATION_SUMMARY.md
PROJECT_READY.md
PROJECT_STATUS.md
COMPLETION_*.md
DOCKER_STATUS.txt
P1_TASKS_COMPLETE.md

# 技术报告目录（内部评估）
docs/reports/

# 历史归档文档
docs/archive/

# 验证和检查报告
docs/GUIDES_CHECK_REPORT.md
docs/REPORT_ORGANIZATION.md
docs/DOCUMENTATION_INDEX.md
docs/PROJECT_STRUCTURE.md
docs/MIGRATION_GUIDE.md

# 前端问题报告
frontend/ISSUES_REPORT.md
frontend/FEATURE_CHECKLIST.md

# 备份文件
*_backup.py
*_old.py
*_enhanced.py

# ==================== Python ====================
# 字节码
__pycache__/
*.py[cod]
*$py.class
*.so

# 分发/打包
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.whl

# 虚拟环境
venv/
env/
ENV/
.venv

# 测试和覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
coverage.xml
*.cover
.ruff_cache/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ==================== Node.js ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm
.eslintcache
.node_repl_history

# ==================== 前端构建产物 ====================
frontend/dist/
frontend/build/
frontend/.cache/

# ==================== IDE 和编辑器 ====================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json.example

# PyCharm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.swp

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# ==================== 操作系统 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ==================== 临时文件 ====================
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
tmp/
temp/

# ==================== Docker ====================
# 保留 Docker 配置文件
!Dockerfile
!docker-compose*.yml
!.dockerignore

# Docker 数据卷
.docker-data/

# ==================== Jupyter Notebook ====================
.ipynb_checkpoints
*.ipynb

# ==================== 其他 ====================
# SSL 证书和密钥
*.pem
*.key
*.crt
*.p12
*.pfx

# 压缩文件
*.zip
*.tar
*.gz
*.rar
*.7z

# 数据文件（大文件）
*.csv
*.xlsx
!package.json
!package-lock.json
!tsconfig.json

# 媒体文件
*.mp4
*.avi
*.mov
*.mp3
*.wav

# 保留必要的空目录
!data/.gitkeep
!logs/.gitkeep

# ==================== 部署脚本（内部）====================
deploy.bat
start.bat
start.ps1
