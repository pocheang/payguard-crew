# ============================================
# PayGuard 生产环境配置模板
# ============================================
# 🔴 警告：这是生产环境配置，必须修改所有默认值！

# 应用配置
APP_NAME=payguard-crew
APP_ENV=production
APP_VERSION=0.2.0
DEBUG=false

# ============================================
# 🔒 安全配置（必须修改！）
# ============================================

# JWT 认证密钥（至少32个字符）
# 🚨 必须生成新密钥！生成方式：
# Linux/Mac: openssl rand -base64 32
# Windows PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_KEY_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30  # 生产环境建议短时效

# API 密钥（必须修改！）
# 🚨 生成强密钥，不要使用示例值
API_KEYS=CHANGE_THIS_TO_YOUR_PRODUCTION_API_KEYS

# ============================================
# 数据库配置（生产环境必须使用 PostgreSQL）
# ============================================

# 使用 PostgreSQL 以获得更好的性能和可靠性
DATABASE_TYPE=postgres

# PostgreSQL 配置
POSTGRES_DB=payguard
POSTGRES_USER=payguard
# 🚨 必须设置强密码！
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_DATABASE_PASSWORD
DATABASE_URL=postgresql://payguard:CHANGE_THIS_TO_SECURE_DATABASE_PASSWORD@postgres:5432/payguard

# ============================================
# Redis 配置（生产环境强烈推荐）
# ============================================
# 用于缓存和分布式限流
# 🚨 必须设置强密码！
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_TO_SECURE_REDIS_PASSWORD@redis:6379/0

# ============================================
# LLM 配置（根据需求配置）
# ============================================

# 选择 LLM 提供商
LLM_PROVIDER=disabled  # 选项: disabled, deepseek, openai, ollama

# DeepSeek 配置（推荐：性价比高）
# 🔑 如需使用，请配置真实 API Key
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 配置
# 🔑 如需使用，请配置真实 API Key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Ollama 配置（不推荐生产环境，除非自建）
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# LLM 超时配置
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ============================================
# CrewAI 配置
# ============================================
ENABLE_CREWAI=false

# ============================================
# RAG 配置
# ============================================
RAG_TOP_K=3
PAYGUARD_DOCS_DIR=/app/docs

# ============================================
# 安全与限流配置（生产环境严格）
# ============================================

# CORS 配置
# 🚨 必须配置具体的前端域名，禁止使用 * 通配符！
# 多个域名用逗号分隔
CORS_ORIGINS=https://your-frontend-domain.com,https://admin.your-domain.com

# 速率限制（必须启用）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ============================================
# 日志与监控配置
# ============================================

# 日志级别（生产环境使用 INFO 或 WARNING）
LOG_LEVEL=INFO

# 启用监控指标
ENABLE_METRICS=true

# Sentry 错误追踪（强烈推荐生产环境启用）
# 🔑 配置你的 Sentry DSN
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# OpenTelemetry 分布式追踪（可选）
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector:4317

# ============================================
# 生产环境安全配置
# ============================================

# 禁用热重载
RELOAD=false

# 不显示详细错误信息
SHOW_ERROR_DETAILS=false

# 不输出 SQL 查询日志
SQL_ECHO=false

# ============================================
# Docker 构建参数
# ============================================
BUILD_DATE=2024-01-01
VERSION=0.2.0

# ============================================
# 前端配置
# ============================================
# 🚨 必须配置为实际的后端 API 地址
VITE_API_URL=https://api.your-domain.com

# ============================================
# 备份配置（可选）
# ============================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点备份
# BACKUP_RETENTION_DAYS=30

# ============================================
# SSL/TLS 配置（如果使用）
# ============================================
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ============================================
# 🚨 生产环境检查清单
# ============================================
# 在部署前请确认：
# [ ] JWT_SECRET_KEY 已修改为强随机密钥
# [ ] POSTGRES_PASSWORD 已修改为强密码
# [ ] REDIS_PASSWORD 已修改为强密码
# [ ] API_KEYS 已修改为生产密钥
# [ ] CORS_ORIGINS 已配置为实际域名
# [ ] VITE_API_URL 已配置为实际API地址
# [ ] DEBUG=false
# [ ] LOG_LEVEL=INFO
# [ ] RATE_LIMIT_ENABLED=true
# [ ] 已配置 Sentry（推荐）
# [ ] 已配置 SSL 证书（如果对外服务）
# [ ] 已设置定期备份策略
