# ============================================
# PayGuard 开发环境配置
# ============================================
# 此配置用于本地开发，优先考虑便捷性和调试

# 应用配置
APP_NAME=payguard-crew
APP_ENV=development
APP_VERSION=0.2.0
DEBUG=true

# ============================================
# 🔒 安全配置（开发环境默认值）
# ============================================

# JWT 认证密钥（开发环境使用固定值，方便调试）
JWT_SECRET_KEY=dev-secret-key-not-for-production-12345678
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24小时，开发时不频繁过期

# API 密钥（开发环境默认值）
API_KEYS=demo-test-key-12345,dev-api-key-67890

# ============================================
# 数据库配置（开发环境使用 SQLite）
# ============================================

# 使用 SQLite，无需额外安装数据库
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=./data/payguard_dev.db

# PostgreSQL 配置（如果需要测试 PostgreSQL）
POSTGRES_DB=payguard_dev
POSTGRES_USER=payguard
POSTGRES_PASSWORD=dev_password_123
DATABASE_URL=postgresql://payguard:dev_password_123@localhost:5432/payguard_dev

# ============================================
# Redis 配置（开发环境可选）
# ============================================
# 开发环境默认不使用 Redis，使用内存缓存
REDIS_PASSWORD=dev_redis_123
REDIS_URL=redis://:dev_redis_123@localhost:6379/0

# ============================================
# LLM 配置（开发环境）
# ============================================

# 开发环境默认禁用 AI 功能，避免 API 消耗
LLM_PROVIDER=disabled

# DeepSeek 配置（如需测试 AI 功能）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 配置（如需测试 AI 功能）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Ollama 配置（推荐开发环境使用）
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434/v1

# LLM 超时配置（开发环境更宽松）
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# ============================================
# CrewAI 配置
# ============================================
ENABLE_CREWAI=false

# ============================================
# RAG 配置
# ============================================
RAG_TOP_K=3
PAYGUARD_DOCS_DIR=./docs

# ============================================
# 安全与限流配置（开发环境宽松）
# ============================================

# CORS 配置（开发环境允许所有本地源）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# 速率限制（开发环境宽松）
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_HOUR=10000

# ============================================
# 日志与监控配置（开发环境详细日志）
# ============================================

LOG_LEVEL=DEBUG  # 开发环境使用详细日志
ENABLE_METRICS=true

# Sentry 错误追踪（开发环境通常不启用）
# SENTRY_DSN=

# OpenTelemetry（开发环境通常不启用）
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ============================================
# 开发工具配置
# ============================================

# 热重载
RELOAD=true

# 显示详细错误信息
SHOW_ERROR_DETAILS=true

# SQL 查询日志
SQL_ECHO=true

# ============================================
# Docker 开发配置
# ============================================
BUILD_DATE=2024-01-01
VERSION=0.2.0

# 前端配置
VITE_API_URL=http://localhost:8000/api
