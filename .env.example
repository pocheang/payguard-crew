# 应用配置
APP_NAME=payguard-crew
APP_ENV=dev

# 🔒 API 认证配置（生产环境必须配置）
# 开发环境：不配置 API_KEYS 则允许所有请求（不安全）
# 生产环境：必须配置强随机 API Keys
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# ⚠️ 警告：请勿在生产环境使用默认或测试密钥！

# LLM 配置（可选，不配置则使用规则引擎模式）
LLM_PROVIDER=disabled              # 选项: disabled, openai, deepseek, ollama
DEEPSEEK_API_KEY=sk-REPLACE-WITH-YOUR-ACTUAL-DEEPSEEK-API-KEY
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=sk-REPLACE-WITH-YOUR-ACTUAL-OPENAI-API-KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434/v1

# CrewAI 配置
ENABLE_CREWAI=false                # 是否启用 CrewAI 编排

# RAG 配置
RAG_TOP_K=3                        # 检索返回数量
PAYGUARD_DOCS_DIR=docs             # 知识库目录

# 数据库配置
SQLITE_DB_PATH=./payguard_crew.db  # SQLite 数据库路径

# LLM 超时配置
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# CORS 配置（前端集成时配置）
CORS_ORIGINS=
# 示例：CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 速率限制配置
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_PER_HOUR=1000

# 监控配置
ENABLE_METRICS=true
